---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import { SITE_CONFIG } from '@/constants/site';
import { getUi, localizePath, type Locale } from '@/i18n';
import '@/styles/global.css';

interface Props {
  locale: Locale;
  currentPath: string;
  title: string;
  activeSlug: 'overview' | 'install' | 'structure' | 'evolution' | 'skills' | 'tips';
}

const { locale, currentPath, title, activeSlug } = Astro.props;
const ui = getUi(locale);

const navItems = [
  { slug: 'overview' as const, label: ui.docsOverview, href: localizePath('/docs/overview', locale) },
  { slug: 'install' as const, label: ui.docsInstall, href: localizePath('/docs/install', locale) },
  { slug: 'structure' as const, label: ui.docsStructure, href: localizePath('/docs/structure', locale) },
  { slug: 'evolution' as const, label: ui.docsEvolution, href: localizePath('/docs/evolution', locale) },
  { slug: 'skills' as const, label: ui.docsSkills, href: localizePath('/docs/skills', locale) },
  { slug: 'tips' as const, label: ui.navTips, href: localizePath('/docs/tips', locale) },
];
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} | {SITE_CONFIG.siteName}</title>
  </head>
  <body class="min-h-[100dvh] bg-[var(--color-surface)]">
    <Header locale={locale} currentPath={currentPath} />
    <div class="mx-auto grid max-w-7xl gap-8 px-4 pb-10 pt-24 lg:grid-cols-[220px_1fr] lg:gap-12">
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <details class="group lg:hidden" open>
          <summary class="cursor-pointer rounded-[var(--radius-md)] border border-[var(--color-border)] px-4 py-3 text-sm font-medium">
            {ui.navDocs}
          </summary>
          <nav class="mt-3 flex flex-col gap-1 border-l border-[var(--color-border)] pl-4">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'rounded px-3 py-2 text-sm transition',
                    activeSlug === item.slug
                      ? 'bg-[var(--color-accent-muted)] font-medium text-[var(--color-accent)]'
                      : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
                  ]}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </details>
        <nav class="hidden flex-col gap-1 lg:flex">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'rounded-[var(--radius-sm)] px-3 py-2 text-sm transition',
                  activeSlug === item.slug
                    ? 'bg-[var(--color-accent-muted)] font-medium text-[var(--color-accent)]'
                    : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-text-primary)]',
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </aside>
      <main class="min-w-0 w-full">
        <slot />
      </main>
    </div>
    <Footer locale={locale} />
  </body>
</html>
