---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
import { SITE_CONFIG } from '@/constants/site';
import { getUi, localizePath, type Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = getUi(locale);
---

<footer class="border-t border-[var(--color-border)] py-10">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-semibold text-[var(--color-text-primary)]">{SITE_CONFIG.siteName}</p>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">{ui.footerTagline}</p>
    </div>
    <div class="flex items-center gap-6 text-sm">
      <a
        href={localizePath('/docs/overview', locale)}
        class="text-[var(--color-text-secondary)] transition hover:text-[var(--color-accent)]"
      >
        {ui.footerDocs}
      </a>
      <a
        href={localizePath('/docs/tips', locale)}
        class="text-[var(--color-text-secondary)] transition hover:text-[var(--color-accent)]"
      >
        {ui.footerTips}
      </a>
      <span class="font-mono text-[var(--color-text-muted)]">v{SITE_CONFIG.version}</span>
    </div>
  </div>
</footer>
