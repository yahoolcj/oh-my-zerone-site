---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
interface Props {
  text: string;
  label: string;
  copiedLabel: string;
}

const { text, label, copiedLabel } = Astro.props;
---

<button
  type="button"
  class="copy-btn shrink-0 rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-3 py-1.5 text-sm font-medium text-[var(--color-text-primary)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] active:scale-[0.98]"
  data-copy-text={text}
  data-label={label}
  data-copied-label={copiedLabel}
>
  {label}
</button>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const text = el.dataset.copyText ?? '';
      const label = el.dataset.label ?? 'Copy';
      const copied = el.dataset.copiedLabel ?? 'Copied';
      try {
        await navigator.clipboard.writeText(text);
        el.textContent = copied;
        setTimeout(() => {
          el.textContent = label;
        }, 2000);
      } catch {
        el.textContent = 'Failed';
        setTimeout(() => {
          el.textContent = label;
        }, 2000);
      }
    });
  });
</script>
