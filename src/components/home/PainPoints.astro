---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
import { PainPointsGrid } from '@/components/react-bits/PainPointsGrid';
import Reveal from '@/components/ui/Reveal.astro';
import { PAIN_POINTS } from '@/constants/pain-points';
import { getUi, type Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = getUi(locale);
const items = PAIN_POINTS.map((item) => ({
  title: locale === 'zh' ? item.titleZh : item.titleEn,
  description: locale === 'zh' ? item.descriptionZh : item.descriptionEn,
}));
---

<section class="border-t border-[var(--color-border)] py-20 md:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <Reveal>
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{ui.painTitle}</h2>
      <p class="mt-3 max-w-2xl text-[var(--color-text-secondary)]">{ui.painSubtitle}</p>
    </Reveal>

    <div class="mt-10">
      <PainPointsGrid client:visible items={items} />
    </div>
  </div>
</section>
