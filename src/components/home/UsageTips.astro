---
/**
 * @by oh-my-zerone
 * @date 2026-07-18
 *
 * 首页「使用技巧」区块。
 * 从 Content Collection `tips` 读取数据，按 order 升序排列，limit 控制展示条数。
 */
import { getCollection } from 'astro:content';
import { UsageTipsList } from '@/components/react-bits/UsageTipsList';
import Reveal from '@/components/ui/Reveal.astro';
import { getUi, localizePath, type Locale } from '@/i18n';

interface Props {
  locale: Locale;
  limit?: number;
}

const { locale, limit = 6 } = Astro.props;
const ui = getUi(locale);

const allTips = await getCollection('tips');
const sorted = allTips.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const displayTips = limit ? sorted.slice(0, limit) : sorted;

const tips = displayTips.map((tip, i) => ({
  slug: tip.id,
  index: i + 1,
  title: locale === 'zh' ? tip.data.titleZh : tip.data.titleEn,
  summary: locale === 'zh' ? tip.data.summaryZh : tip.data.summaryEn,
  href: localizePath(`/docs/tips/${tip.id}`, locale),
}));
---

{
  allTips.length > 0 && (
    <section class="border-t border-[var(--color-border)] py-20 md:py-24">
      <div class="mx-auto max-w-7xl px-4">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <Reveal>
            <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{ui.tipsTitle}</h2>
            <p class="mt-3 max-w-2xl text-[var(--color-text-secondary)]">{ui.tipsSubtitle}</p>
          </Reveal>
          {
            limit && allTips.length > limit && (
              <a
                href={localizePath('/docs/tips', locale)}
                class="text-sm font-medium text-[var(--color-accent)] transition hover:text-[var(--color-accent-hover)]"
              >
                {ui.tipsViewAll}
              </a>
            )
          }
        </div>

        <div class="mt-10">
          <UsageTipsList client:visible tips={tips} />
        </div>
      </div>
    </section>
  )
}
