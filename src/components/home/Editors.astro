---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
import { EditorsGlowGrid } from '@/components/react-bits';
import Reveal from '@/components/ui/Reveal.astro';
import { EDITORS } from '@/constants/editors';
import { getUi, type Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = getUi(locale);
---

<section class="border-t border-[var(--color-border)] bg-[var(--color-surface-elevated)] py-20 md:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <Reveal>
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{ui.editorsTitle}</h2>
      <p class="mt-3 max-w-2xl text-[var(--color-text-secondary)]">{ui.editorsSubtitle}</p>
    </Reveal>

    <div class="mt-10">
      <EditorsGlowGrid client:visible editors={EDITORS} />
    </div>
  </div>
</section>
