---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
export interface Props {
  label?: string;
}

const { label = 'terminal' } = Astro.props;
---

<div class="rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden">
  <div class="flex items-center gap-1.5 border-b border-[var(--color-border)] px-4 py-2 bg-[var(--color-surface-muted)]">
    <span class="h-3 w-3 rounded-full bg-[#ef4444]" />
    <span class="h-3 w-3 rounded-full bg-[#f59e0b]" />
    <span class="h-3 w-3 rounded-full bg-[#10b981]" />
    <span class="ml-2 text-xs text-[var(--color-text-muted)] font-mono">{label}</span>
  </div>
  <div class="overflow-x-auto">
    <slot />
  </div>
</div>
