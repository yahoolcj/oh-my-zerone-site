---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
import DocsLayout from '@/layouts/DocsLayout.astro';
import TerminalChrome from '@/components/docs/TerminalChrome.astro';
import VisionConfigGuide from '@/components/react-bits/VisionConfigGuide';
import { getSkillBySlug, getAllSkills } from '@/lib/skills';
import { renderMarkdown } from '@/lib/markdown';

export function getStaticPaths() {
  return getAllSkills().map((skill) => ({
    params: { slug: skill.slug },
  }));
}

const { slug } = Astro.params;
const skill = getSkillBySlug(slug!);
if (!skill) throw new Error(`Skill not found: ${slug}`);

const showcaseBody = skill.showcaseEn;
const splitIdx = showcaseBody.indexOf('\n## Example Effects');
const scenarioMd = splitIdx !== -1 ? showcaseBody.slice(0, splitIdx) : showcaseBody;
const exampleMd = splitIdx !== -1 ? showcaseBody.slice(splitIdx) : '';
const scenarioHtml = renderMarkdown(scenarioMd);
const exampleHtml = exampleMd ? renderMarkdown(exampleMd) : '';
---

<DocsLayout locale="en" currentPath={`/en/docs/skills/${skill.slug}`} title={skill.name} activeSlug="skills">
  <article class="prose-docs">
    <h1>/{skill.name}</h1>
    <p class="text-[var(--color-text-secondary)]">{skill.descriptionEn}</p>
  </article>

  <!-- Use Scenario (prose style) -->
  {
    scenarioHtml && (
      <div class="prose-docs mt-8" set:html={scenarioHtml} />
    )
  }

  <!-- Example Effects (terminal style) -->
  {
    exampleHtml && (
      <div class="mt-8">
        <TerminalChrome>
          <div set:html={exampleHtml} />
        </TerminalChrome>
      </div>
    )
  }

  <!-- Vision Config Guide (image-to-context only) -->
  {
    slug === 'image-to-context' && (
      <VisionConfigGuide locale="en" client:load />
    )
  }
</DocsLayout>
