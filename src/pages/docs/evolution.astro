---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
import DocsLayout from '@/layouts/DocsLayout.astro';
import { getDocEntry } from '@/lib/docs';
import { render } from 'astro:content';

const entry = await getDocEntry('zh', 'evolution');
if (!entry) throw new Error('evolution doc not found');
const { Content } = await render(entry);
---

<DocsLayout locale="zh" currentPath="/docs/evolution" title={entry.data.title} activeSlug="evolution">
  <article class="prose-docs">
    <Content />
  </article>
</DocsLayout>
