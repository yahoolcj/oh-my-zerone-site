---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
import DirectorySteps from '@/components/home/DirectorySteps.astro';
import DocsLayout from '@/layouts/DocsLayout.astro';
import { getUi } from '@/i18n';
import { getDocEntry } from '@/lib/docs';
import { render } from 'astro:content';

const entry = await getDocEntry('zh', 'install');
if (!entry) throw new Error('install doc not found');
const { Content } = await render(entry);
const ui = getUi('zh');
---

<DocsLayout locale="zh" currentPath="/docs/install" title={entry.data.title} activeSlug="install">
  <p class="mb-6 rounded-[var(--radius-md)] border border-[var(--color-accent-muted)] bg-[var(--color-accent-muted)]/30 px-4 py-3 text-sm text-[var(--color-text-secondary)]">
    {ui.installNoteInternal}
  </p>
  <article class="prose-docs">
    <Content />
  </article>
  <div class="mt-12">
    <DirectorySteps locale="zh" variant="full" />
  </div>
</DocsLayout>
