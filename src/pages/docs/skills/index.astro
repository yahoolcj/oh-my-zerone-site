---
/**
 * @by oh-my-zerone
 * @date 2026-06-10
 */
import DocsLayout from '@/layouts/DocsLayout.astro';
import { getAllSkills } from '@/lib/skills';
import { getUi, localizePath } from '@/i18n';
import SkillGrid from '@/components/react-bits/SkillGrid';

const skills = getAllSkills();
const ui = getUi('zh');

const filterLabels = {
  all: ui.skillsFilterAll,
  clarify: ui.skillsFilterClarify,
  plan: ui.skillsFilterPlan,
  develop: ui.skillsFilterDevelop,
  review: ui.skillsFilterReview,
  utility: ui.skillsFilterUtility,
};
---

<DocsLayout locale="zh" currentPath="/docs/skills" title={ui.docsSkills} activeSlug="skills">
  <div class="prose-docs mb-6">
    <h1>{ui.docsSkills}</h1>
    <p>{ui.skillsSubtitle}</p>
  </div>
  <SkillGrid
    skills={skills}
    filterLabels={filterLabels}
    basePath={localizePath('/docs/skills', 'zh')}
    locale="zh"
    client:load
  />
</DocsLayout>
